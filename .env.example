# =============================================
# OPCIÓN 1: Railway (recomendado ☁️)
# Copia el valor de DATABASE_URL desde tu
# proyecto en Railway > Variables
# =============================================
DATABASE_URL=mysql://user:password@host.railway.app:port/railway

# =============================================
# OPCIÓN 2: Base de datos local (desarrollo)
# Comenta DATABASE_URL y usa estas variables
# =============================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=parqueadero_usc

# =============================================
# JWT - Cambia esto por un secreto seguro
# =============================================
JWT_SECRET=tu_secreto_super_seguro_aqui

# Puerto del servidor
PORT=3000
